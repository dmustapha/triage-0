{
  "name": "triage-0",
  "version": "0.1.0",
  "description": "Offline clinical decision-support for community health workers — 100% on-device via @qvac/sdk.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=22.17"
  },
  "scripts": {
    "spike": "node --expose-gc --import tsx scripts/spike-memory.ts",
    "spike:rag": "node --import tsx scripts/spike3-rag.ts",
    "ingest": "tsx scripts/ingest-protocols.ts",
    "start": "tsx src/server.ts",
    "dev": "tsx watch src/server.ts",
    "typecheck": "tsc --noEmit",
    "test:unit": "node --import tsx --test tests/unit/*.test.ts",
    "test": "node --import tsx --test --test-concurrency=1 tests/unit/*.test.ts tests/integration/*.test.ts"
  },
  "dependencies": {
    "@qvac/sdk": "0.13.3",
    "better-sqlite3": "^11.8.1",
    "express": "^4.21.2",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.5",
    "jsdom": "^29.1.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
