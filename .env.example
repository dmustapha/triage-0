# Triage-0 configuration. All variables are optional; the defaults reproduce the submission.

# HTTP port the server listens on.
PORT=3010

# MedPsy variant: "1.7b" (default, 1.3 GB) or "4b" (larger, higher accuracy).
MODEL_ID=1.7b

# Optional Hugging Face token. Only used to authorize or speed the one-time
# first-run download of the model weights. Inference is always local.
HF_TOKEN=

# Retrieval similarity floor. Below this, Triage-0 abstains (UNKNOWN card) rather
# than surface a weak citation.
RAG_THRESHOLD=0.70

# Model residency strategy: resident | hybrid | sequential | fallback.
RESIDENT_MODE=resident
